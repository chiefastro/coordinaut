# Coordinaut Configuration
# Copy to .env and modify as needed

# COORDINAUT_API_HOST=127.0.0.1
# COORDINAUT_API_PORT=8787
# COORDINAUT_DB_PATH=~/.coordinaut/coordinaut.db
# COORDINAUT_DEFAULT_LEASE_TTL_SECONDS=600

# Linear integration (optional)
# COORDINAUT_LINEAR_API_KEY=lin_api_xxxxx
# COORDINAUT_LINEAR_TEAM_ID=your-team-id

# Launcher config (optional)
# COORDINAUT_LAUNCHER_CONFIG_PATH=./launcher_templates.json
